{
  "name": "tether",
  "displayName": "Claude Code Slack Tether",
  "description": "MCP bridge that links Slack business context to AI coding agents. Search conversations, fetch threads, and code with full context.",
  "keywords": [
    "claude code",
    "slack",
    "mcp",
    "business context",
    "ai coding"
  ],
  "version": "0.1.1",
  "publisher": "jerrychaitea",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jchai002/tether.git"
  },
  "icon": "media/tether-icon.png",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "businessContext.configure",
        "title": "Tether: Configure"
      },
      {
        "command": "tether.openChat",
        "title": "Tether: Open Chat",
        "icon": "media/tether-icon.svg"
      },
      {
        "command": "tether.viewTelemetryData",
        "title": "Tether: View Collected Data"
      },
      {
        "command": "tether.deleteTelemetryData",
        "title": "Tether: Delete Collected Data"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "tether.openChat",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Tether",
      "properties": {
        "businessContext.contextProvider": {
          "type": "string",
          "default": "slack",
          "enum": [
            "slack",
            "mock"
          ],
          "enumDescriptions": [
            "Slack (via User OAuth Token)",
            "Mock (built-in test data)"
          ],
          "description": "Which communication platform to pull business context from.",
          "order": 1
        },
        "businessContext.codingAgent": {
          "type": "string",
          "default": "claude-code-cli",
          "enum": [
            "claude-code-cli"
          ],
          "enumDescriptions": [
            "Claude Code CLI (multi-turn agentic conversations)"
          ],
          "description": "Which AI coding tool to use for implementation.",
          "order": 2
        },
        "businessContext.slack.userToken": {
          "type": "string",
          "default": "",
          "description": "Slack User OAuth Token (xoxp-...). Required when using Slack as context provider.",
          "order": 10
        },
        "businessContext.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable local logging of anonymous usage data (AI responses + interaction metadata). Turn this on to re-enable logging if you previously declined the consent prompt. Data is stored at ~/.tether/telemetry/sessions.jsonl.",
          "order": 20
        },
        "businessContext.telemetry.syncEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Periodically upload collected telemetry to Tether's servers for training better context search. Requires telemetry.enabled. Data is anonymous (device ID only, no email or identity).",
          "order": 21
        },
        "businessContext.maxSearchResults": {
          "type": "number",
          "default": 20,
          "description": "Maximum number of messages to retrieve per search.",
          "order": 30
        },
        "businessContext.maxThreadMessages": {
          "type": "number",
          "default": 50,
          "description": "Maximum number of messages to retrieve per thread.",
          "order": 31
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "postinstall": "cd webview-ui && npm install",
    "build": "node esbuild.mjs",
    "build:webview": "cd webview-ui && npm run build",
    "watch": "node esbuild.mjs --watch",
    "lint": "tslint -p .",
    "test": "vitest run",
    "test:webview": "cd webview-ui && npm test",
    "test:all": "vitest run && cd webview-ui && npm test",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.93.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.34",
    "@slack/web-api": "^7.0.0",
    "zod": "^4.3.6"
  }
}
